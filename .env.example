# Copy to .env.local (gitignored) and fill in from Supabase → Project Settings → API.
# The publishable key is safe for the client — RLS is what actually protects data.
#
# NEXT_PUBLIC_* vars are inlined into the browser bundle at BUILD time, so they
# must be set in the Vercel project settings (not just at runtime) for a real
# deploy. CI builds without them on purpose (it's a gate, never deployed).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
